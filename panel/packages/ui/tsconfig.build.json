{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "noEmit": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "dist",
    "node_modules",
    "build.mjs",
    "src/wraps.ts",
    "src/charts.ts",
    "src/icons.ts"
  ]
}
