{
  "name": "@servicecoreui/ui",
  "version": "0.2.0",
  "description": "ServiceCore UI library — AntD 5.7 wrapped components with CSS Modules",
  "license": "UNLICENSED",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gorgonline/servicecore.git",
    "directory": "panel/packages/ui"
  },
  "homepage": "https://github.com/gorgonline/servicecore/tree/main/panel/packages/ui",
  "bugs": {
    "url": "https://github.com/gorgonline/servicecore/issues"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./custom": {
      "types": "./dist/custom.d.ts",
      "import": "./dist/custom.js",
      "require": "./dist/custom.cjs"
    },
    "./wraps": {
      "types": "./dist/wraps.d.ts",
      "import": "./dist/wraps.js",
      "require": "./dist/wraps.cjs"
    },
    "./charts": {
      "types": "./dist/charts.d.ts",
      "import": "./dist/charts.js",
      "require": "./dist/charts.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    },
    "./theme/tokens.css": "./dist/theme/tokens.css",
    "./tokens.css": "./dist/theme/tokens.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.build.json",
    "build:js": "node build.mjs",
    "build:dts": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint placeholder'"
  },
  "peerDependencies": {
    "@carbon/icons-react": ">=11.0.0",
    "antd": ">=5.7.0",
    "dayjs": "^1.11.20",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@carbon/icons-react": "^11.50.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "antd": "5.7.0",
    "dayjs": "^1.11.20",
    "esbuild": "^0.27.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
