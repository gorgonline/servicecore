{
  "handoff": {
    "from": "@Motion-Master",
    "to": "@Next-Code-Master",
    "summary": "/test-odasi için spring tabanlı animasyonlar ve etkileşim şeması tamamlandı.",
    "deliverables": {
      "motionSpec": {
        "entrance": {
          "type": "stagger",
          "delay": 0.1,
          "animation": { "initial": { "opacity": 0, "y": 20 }, "animate": { "opacity": 1, "y": 0 }, "transition": { "type": "spring", "stiffness": 100 } }
        },
        "interactions": {
          "BentoItem": { "hover": { "scale": 1.02, "shadow": "0_20px_40px_rgba(0,0,0,0.4)" } },
          "LiveFeed": { "pulse": { "scale": [1, 1.05, 1], "opacity": [0.8, 1, 0.8] } }
        },
        "accessibility": { "prefersReducedMotion": "disable-animations" }
      }
    }
  }
}
