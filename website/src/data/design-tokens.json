{
  "typography": {
    "fontFamily": {
      "sans": "var(--font-geist-sans), system-ui, sans-serif",
      "mono": "var(--font-geist-mono), monospace"
    },
    "heading": {
      "h1": {
        "size": "text-5xl md:text-6xl lg:text-7xl",
        "weight": "font-bold",
        "tracking": "tracking-tight",
        "leading": "leading-[1.1]",
        "color": "text-white"
      },
      "h2": {
        "size": "text-3xl lg:text-4xl",
        "weight": "font-bold",
        "tracking": "tracking-tight",
        "color": "text-white"
      },
      "h3": {
        "size": "text-xl lg:text-2xl",
        "weight": "font-semibold",
        "tracking": "tracking-tight",
        "color": "text-white"
      },
      "h4": {
        "size": "text-lg",
        "weight": "font-semibold",
        "tracking": "tracking-tight",
        "color": "text-white"
      }
    },
    "body": {
      "lead": {
        "size": "text-lg lg:text-xl",
        "weight": "font-light",
        "leading": "leading-relaxed",
        "color": "text-slate-400"
      },
      "base": {
        "size": "text-base",
        "weight": "font-light",
        "leading": "leading-relaxed",
        "color": "text-slate-400"
      },
      "small": {
        "size": "text-sm",
        "weight": "font-light",
        "leading": "leading-relaxed",
        "color": "text-slate-400"
      }
    },
    "label": {
      "size": "text-sm",
      "weight": "font-medium",
      "color": "text-slate-400"
    },
    "overline": {
      "size": "text-xs",
      "weight": "font-semibold",
      "tracking": "tracking-[0.2em]",
      "transform": "uppercase",
      "color": "text-slate-300"
    },
    "caption": {
      "size": "text-xs",
      "weight": "font-medium",
      "color": "text-slate-500"
    }
  },

  "colors": {
    "brand": {
      "primary": "#0070F3",
      "primaryHover": "#0060D0",
      "secondary": "#10B981",
      "accent": "#38BDF8"
    },
    "surface": {
      "base": "#010E21",
      "elevated": "rgba(255,255,255,0.02)",
      "elevatedHover": "rgba(255,255,255,0.04)",
      "overlay": "rgba(255,255,255,0.05)"
    },
    "border": {
      "subtle": "rgba(255,255,255,0.05)",
      "default": "rgba(255,255,255,0.10)",
      "active": "rgba(0,112,243,0.50)"
    },
    "text": {
      "primary": "#FFFFFF",
      "secondary": "#94A3B8",
      "muted": "#64748B",
      "brand": "#0070F3"
    }
  },

  "spacing": {
    "section": {
      "padding": "py-24",
      "gap": "space-y-24"
    },
    "container": {
      "padding": "px-6 lg:px-12",
      "maxWidth": "max-w-7xl"
    },
    "component": {
      "cardPadding": "p-8",
      "stackGap": "gap-6",
      "gridGap": "gap-6"
    }
  },

  "buttons": {
    "primary": {
      "base": "inline-flex items-center justify-center gap-2 bg-[#0070F3] text-white font-medium rounded-full shadow-[0_0_20px_-5px_rgba(0,112,243,0.5)] transition-all hover:shadow-[0_0_30px_-5px_rgba(0,112,243,0.6)] cursor-pointer",
      "sizes": {
        "lg": "h-14 px-8 text-base",
        "md": "h-11 px-6 text-sm",
        "sm": "h-9 px-4 text-sm"
      }
    },
    "secondary": {
      "base": "inline-flex items-center justify-center gap-2 bg-white/5 border border-white/10 text-white font-medium rounded-full transition-all hover:bg-white/10 cursor-pointer",
      "sizes": {
        "lg": "h-14 px-8 text-base",
        "md": "h-11 px-6 text-sm",
        "sm": "h-9 px-4 text-sm"
      }
    },
    "ghost": {
      "base": "inline-flex items-center justify-center gap-2 text-slate-300 font-medium transition-all hover:text-white cursor-pointer",
      "sizes": {
        "lg": "h-14 px-6 text-base",
        "md": "h-11 px-4 text-sm",
        "sm": "h-9 px-3 text-sm"
      }
    }
  },

  "borders": {
    "radius": {
      "sm": "rounded-lg",
      "md": "rounded-xl",
      "lg": "rounded-2xl",
      "full": "rounded-full"
    }
  },

  "shadows": {
    "glow": {
      "primary": "shadow-[0_0_20px_-5px_rgba(0,112,243,0.5)]",
      "primaryStrong": "shadow-[0_0_30px_-5px_rgba(0,112,243,0.6)]"
    },
    "elevation": {
      "sm": "shadow-sm",
      "md": "shadow-md",
      "lg": "shadow-2xl"
    }
  },

  "animation": {
    "timing": {
      "instant": "100ms",
      "fast": "200ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easing": {
      "default": "ease-out",
      "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    }
  },

  "icons": {
    "size": {
      "sm": 16,
      "md": 20,
      "lg": 24,
      "xl": 32,
      "hero": 48
    },
    "strokeWidth": {
      "thin": 1,
      "default": 1.5,
      "medium": 2
    }
  },

  "effects": {
    "glass": {
      "base": "bg-white/5 border border-white/10 backdrop-blur-xl",
      "hover": "hover:bg-white/10 hover:border-white/20 hover:backdrop-blur-2xl transition-all duration-300",
      "active": "bg-white/10 border-white/20 backdrop-blur-3xl"
    },
    "blur": {
      "sm": "blur-md",
      "md": "blur-xl",
      "lg": "blur-[100px]",
      "xl": "blur-[150px]"
    },
    "gradient": {
      "brand": "bg-gradient-to-br from-[#0070F3] to-[#A855F7]",
      "brandText": "text-transparent bg-clip-text bg-gradient-to-r from-[#0070F3] to-cyan-400",
      "surface": "bg-gradient-to-br from-white/5 to-transparent",
      "glow": "bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-[#0070F3]/20 to-transparent"
    }
  }
}
