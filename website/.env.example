# Google Apps Script Web App endpoint — "Servicecore Formlar" Sheets'e POST atar
# Lokal: .env.local'a kopyala. Production: Vercel Environment Variables'a ekle.
NEXT_PUBLIC_FORMS_ENDPOINT=https://script.google.com/macros/s/REPLACE_WITH_DEPLOYMENT_ID/exec

# Google Analytics 4 Measurement ID — analytics.google.com → Admin → Data Streams
# Bos birakilirsa GA4 yuklenmez (dev'de tracking kapali kalsin diye).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads Conversion ID — ads.google.com → Tools → Conversions → Tag setup
# Bos birakilirsa Google Ads global tag yuklenmez.
NEXT_PUBLIC_GADS_CONVERSION_ID=AW-XXXXXXXXXX

# Google Ads Demo Form Conversion Label — Conversion action olusturulduktan sonra alinir
# "send_to" formati: AW-XXXXXXXXXX/CONVERSION_LABEL — burada sadece LABEL kismi.
NEXT_PUBLIC_GADS_DEMO_CONVERSION_LABEL=
