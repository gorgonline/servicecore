{
  "name": "sc-temp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "tokens": "node ../scripts/generate-tokens.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "spell": "cspell \"src/**/*.{ts,tsx,mdx,json}\" --no-progress --gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "audit": "npm run audit:arch && node .gemini/scripts/token-checker.js && node .gemini/scripts/state-sync-check.js",
    "audit:arch": "node .gemini/scripts/arch-auditor.js",
    "audit:memory": "node .gemini/scripts/memory-guard.js",
    "audit:external": "python3 .gemini/scripts/orkestra-auditor.py",
    "compress": "node .gemini/scripts/state-compressor.js",
    "cleanup": "node .gemini/scripts/checkpoint-manager.js",
    "consolidate": "npm run compress && npm run cleanup && npm run audit:external",
    "simulate": "bash .gemini/scripts/simulate-merge.sh",
    "prepare": "husky",
    "pdf": "node scripts/generate-datasheet-pdf.mjs"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.6",
    "@paper-design/shaders-react": "^0.0.71",
    "@radix-ui/react-slot": "^1.2.4",
    "@superdesign/cli": "^0.3.3",
    "@xyflow/react": "^12.10.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.35.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@carbon/icons": "^11.80.0",
    "@cspell/dict-tr-tr": "^3.0.6",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.0",
    "cspell": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
